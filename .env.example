# ─────────────────────────────────────────────────────────────────
# BlockVision Edu — Environment Variables
#
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your key  (the .env file is git-ignored — never commit it)
# 3. For production:   set these as env vars in Render / Railway dashboard
# ─────────────────────────────────────────────────────────────────

# ── Gemini API ────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use (gemini-1.5-flash is free tier)
GEMINI_MODEL=gemini-1.5-flash

# Detector backend: "gemini" or "color" (OpenCV fallback)
DETECTOR_BACKEND=gemini

# ── App settings (optional) ───────────────────────────────────────
APP_NAME=BlockVision Edu
DEBUG=false
